rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions (Fungsi Penolong)
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Fungsi mencegah SPAM / Payload data terlalu besar (Mencegah serangan pembengkakan tagihan)
    function isValidText(text, maxLength) {
      return text is string && text.size() <= maxLength;
    }

    // 1. ATURAN KOLEKSI PENGGUNA (users)
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      
      // Izinkan pemilik akun mengubah semua data
      // ATAU izinkan pengguna login mengubah HANYA field views, ratingsCache, ratingAverage, ratingCount
      allow update: if isOwner(userId) 
                    || (
                         isAuthenticated() 
                         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'ratingsCache', 'ratingAverage', 'ratingCount'])
                       );
                       
      allow delete: if false; 

      // Subkoleksi ulasan (ratings)
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.raterId == request.auth.uid;
        allow update, delete: if isOwner(request.resource.data.raterId);
      }
    }

    // 2. ATURAN POSTINGAN JASA (posts & mading)
    match /{postType}/{postId} {
      // Terapkan aturan hanya untuk koleksi posts dan mading
      allow read: if postType == 'posts' || postType == 'mading';

      // Orang harus login dan userId di data HARUS SAMA dengan ID asli pembuat
      allow create: if (postType == 'posts' || postType == 'mading')
                    && isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && isValidText(request.resource.data.title, 200)
                    && isValidText(request.resource.data.description, 5000);

      // Hanya pembuat asli yang bisa mengubah konten utama
      // ATAU izinkan pengguna login untuk HANYA menambah/mengurangi commentCount
      allow update: if (postType == 'posts' || postType == 'mading')
                    && (
                         isOwner(resource.data.userId)
                         || (
                              isAuthenticated()
                              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
                            )
                       );

      allow delete: if (postType == 'posts' || postType == 'mading')
                    && isOwner(resource.data.userId);

      // 3. ATURAN KOMENTAR POSTINGAN & MADING
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() 
                      && request.resource.data.userId == request.auth.uid
                      && isValidText(request.resource.data.text, 1500); // Cegah spam teks panjang
        allow update, delete: if isOwner(resource.data.userId);
      }
    }

    // 4. ATURAN PESAN PRIBADI KETAT (conversations)
    match /conversations/{conversationId} {
      // Hacker TIDAK BISA mengintip. Hanya partisipan di dalam chat yang bisa melihat chatnya.
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Saat membuat obrolan baru, ID pembuat harus ada di dalam daftar partisipan
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      // Saat memperbarui (update unread count / last message), pembaruan harus dilakukan oleh partisipan
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Izinkan partisipan menghapus obrolan dari kotak masuk
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

      // 5. ATURAN ISI PESAN KETAT (messages di dalam conversations)
      match /messages/{messageId} {
        // Hanya yang masuk dalam parent conversation (ruang obrolan) yang bisa baca isi pesan
        allow read: if isAuthenticated() 
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        
        allow create: if isAuthenticated() 
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                      && isValidText(request.resource.data.text, 1000); // Batas teks pesan

        // Hanya pengirim pesan yang boleh edit atau hapus pesannya sendiri
        allow update, delete: if isOwner(resource.data.senderId);
      }
    }

    // Kunci semua koleksi asing yang tidak dikenali
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
